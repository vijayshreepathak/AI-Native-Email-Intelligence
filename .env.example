# =============================================================================
# Backend environment — copy this file to .env and paste your keys
# =============================================================================
#
#   cp .env.example .env          # Mac/Linux
#   copy .env.example .env        # Windows
#
# Set at least ONE API key below. Restart uvicorn after editing.
# Full guide: README.md → "Configure environment"
# =============================================================================

# ── Primary Provider ─────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash-lite

# ── First Fallback ───────────────────────────────────────────────────────────
FALLBACK_PROVIDER=groq
FALLBACK_MODEL=llama-3.3-70b-versatile

# ── Second Fallback ──────────────────────────────────────────────────────────
SECONDARY_PROVIDER=openai
SECONDARY_MODEL=gpt-4.1-mini

# ── API Keys (paste from provider dashboards) ────────────────────────────────
# Gemini  → https://aistudio.google.com/apikey
# Groq    → https://console.groq.com/keys
# OpenAI  → https://platform.openai.com/api-keys
# Claude  → https://console.anthropic.com/settings/keys
GEMINI_API_KEY=xxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── General LLM Parameters ───────────────────────────────────────────────────
TEMPERATURE=0
MAX_TOKENS=4096
MAX_RETRIES=5
REQUEST_TIMEOUT=60

# ── Optional: legacy model overrides ─────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash

# ── App settings (local defaults — change for production) ────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./knowledge/vectorstore
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
RETRIEVAL_TOP_K=3

# ── Production only (Render) — leave blank for local dev ─────────────────────
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
CLERK_SECRET_KEY=sk_test_...
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://ainativeemail.vercel.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
