ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./knowledge/embeddings/chroma
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
MAX_RETRIES=3
RETRIEVAL_TOP_K=3

# Neon PostgreSQL — set in Render dashboard (never commit real credentials)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Clerk JWT verification — set in Render dashboard
CLERK_SECRET_KEY=sk_test_...
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Comma-separated frontend URLs
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://ainativeemail.vercel.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
