# =============================================================================
# Dashboard environment — copy this file to .env.local and fill in your values
# =============================================================================
#
#   cd dashboard
#   cp .env.local.example .env.local    # Mac/Linux
#   copy .env.local.example .env.local  # Windows
#
# Restart `npm run dev` after editing.
# =============================================================================

# ── Backend API URL ──────────────────────────────────────────────────────────
# LOCAL: point at your FastAPI server (Terminal 1: uvicorn app.main:app --reload)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# PRODUCTION (Vercel): paste your Render backend URL — no trailing slash
# NEXT_PUBLIC_API_URL=https://your-service-name.onrender.com

# ── Clerk authentication (optional for local dev) ─────────────────────────────
# Get keys from https://dashboard.clerk.com/ → your app → API Keys
#
# Local dev WITHOUT Clerk: leave these blank — backend uses user id "local-dev"
# and history is stored in results/*.json instead of Neon.
#
# Local dev WITH Clerk OR production on Vercel: paste both keys below.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_paste_from_clerk_dashboard
CLERK_SECRET_KEY=sk_test_paste_from_clerk_dashboard

# ── Where each value comes from ───────────────────────────────────────────────
#
# | Variable                          | Paste from                          |
# |-----------------------------------|-------------------------------------|
# | NEXT_PUBLIC_API_URL (local)       | http://127.0.0.1:8000                 |
# | NEXT_PUBLIC_API_URL (production)  | Render → your service → URL         |
# | NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY | Clerk → API Keys → Publishable key  |
# | CLERK_SECRET_KEY                  | Clerk → API Keys → Secret key       |
#
# Backend .env (repo root, NOT this file) needs LLM keys + optional DATABASE_URL.
# See ../.env.example and README → "Configure environment".
